rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users_data/{userId} {
      // Consente lettura/scrittura se autenticato o se l'utente possiede un identificativo locale valido e sicuro per evitare errori di regex
      allow read, write: if (request.auth != null && request.auth.uid == userId) || (userId.size() >= 20 && userId[0:10] == 'local-usr-');
    }
  }
}
